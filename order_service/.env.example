# Environment Variables for Order Service

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT Configuration
JWT_SECRET=your-256-bit-jwt-secret-key-here-minimum-32-characters-long

# Database Configuration (optional, defaults in application.properties)
DB_URL=jdbc:postgresql://localhost:5432/ticketing
DB_USERNAME=ticketing
DB_PASSWORD=secret

# Server Configuration (optional)
SERVER_PORT=8080

# CORS Configuration (optional)
CORS_ALLOWED_ORIGINS=http://localhost:3000
